@{
    ViewData["Title"] = "Secure Gateway Login";
}

<div class="container mt-5" style="max-width: 420px;">
    <div class="text-center mb-4">
        <h3 class="font-weight-bold text-dark">TechMove Systems</h3>
        <span class="text-muted small">Central Management Terminal Terminal</span>
    </div>

    @if (TempData["LogoutMessage"] != null)
    {
        <div class="alert alert-success py-2 text-center small shadow-sm">
            @TempData["LogoutMessage"]
        </div>
    }

    <form asp-action="Login" method="post" class="border p-4 shadow bg-white rounded">
        @Html.AntiForgeryToken()

        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="mb-3">
            <label class="form-label text-secondary small font-weight-bold">Operator Handle</label>
            <input type="text" name="username" class="form-control" autocomplete="off" required />
        </div>

        <div class="mb-3">
            <label class="form-label text-secondary small font-weight-bold">Security Passkey</label>
            <input type="password" name="password" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-dark w-100 mt-2 py-2">Establish Connection</button>
    </form>
</div>