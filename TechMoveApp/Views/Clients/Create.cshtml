@model TechMoveApp.Models.Client

<div class="container mt-4" style="max-width: 500px;">
    <h3>Register Corporate Client</h3>
    <form asp-action="Create" method="post" class="border p-4 bg-light rounded shadow-sm">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">Client / Company Name</label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Operational Territory/Region</label>
            <input asp-for="Region" class="form-control" required />
            <span asp-validation-for="Region" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Contact Details (Email/Phone)</label>
            <input asp-for="ContactDetails" class="form-control" required />
            <span asp-validation-for="ContactDetails" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100">Save Client Profile</button>
    </form>
</div>